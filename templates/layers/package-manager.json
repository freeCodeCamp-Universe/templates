{
  "bun": {
    "devCmd": [
      "bun",
      "run",
      "dev"
    ],
    "lockfile": "bun.lock",
    "manifests": [
      "package.json"
    ],
    "pmInstall": "RUN npm install -g bun"
  },
  "pnpm": {
    "devCmd": [
      "pnpm",
      "run",
      "dev"
    ],
    "lockfile": "pnpm-lock.yaml",
    "manifests": [
      "package.json"
    ],
    "pmInstall": "RUN corepack enable pnpm",
    "preinstall": "npx only-allow pnpm"
  }
}
